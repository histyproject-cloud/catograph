rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 캐릭터 사진: 본인 소유 캐릭터의 사진만 업로드/삭제 가능
    // 읽기는 공유 뷰 고려해 누구나 허용 (URL을 아는 경우만)
    //
    // ownership 체인:
    //   storage path /characters/{charId}/photo
    //   → firestore /characters/{charId}.projectId
    //   → firestore /projects/{projectId}.ownerId
    //   → request.auth.uid 와 일치해야 write/delete 허용
    //
    // 캐릭터 문서가 먼저 생성되어 있어야 사진 업로드 가능 (정상 클라이언트 흐름과 일치)
    match /characters/{charId}/photo {
      function characterDoc() {
        return firestore.get(/databases/(default)/documents/characters/$(charId));
      }

      function isCharacterOwner() {
        let charProjectId = characterDoc().data.projectId;
        let projectOwnerId = firestore.get(/databases/(default)/documents/projects/$(charProjectId)).data.ownerId;
        return request.auth != null && projectOwnerId == request.auth.uid;
      }

      allow read: if true;

      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*')
        && isCharacterOwner();

      allow delete: if isCharacterOwner();
    }
  }
}
