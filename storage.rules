rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // 캐릭터 사진 소유자 확인:
    //   characters/{charId} → projectId → projects/{projectId}.ownerId == request.auth.uid
    function isCharacterOwner(charId) {
      let charDoc = firestore.get(/databases/(default)/documents/characters/$(charId));
      let projectId = charDoc.data.projectId;
      let projDoc = firestore.get(/databases/(default)/documents/projects/$(projectId));
      return request.auth != null && projDoc.data.ownerId == request.auth.uid;
    }

    // 캐릭터 사진:
    //   - 읽기: 공유 뷰 지원을 위해 누구나 허용 (URL 추측이 어려운 charId 기반)
    //   - 쓰기: 프로젝트 소유자만 + 이미지/5MB 제한
    //   - 삭제: 프로젝트 소유자만
    match /characters/{charId}/photo {
      allow read: if true;
      allow write: if isCharacterOwner(charId)
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if isCharacterOwner(charId);
    }
  }
}
