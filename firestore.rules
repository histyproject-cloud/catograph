rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 유저 문서
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;

      // 클라이언트 업데이트: subscription 필드를 건드릴 경우 pendingPlan만 허용
      // (status, billingKey, currentPeriodEnd, plan 등은 Cloud Function만 쓸 수 있음)
      allow update: if request.auth != null && request.auth.uid == uid
        && (
          // subscription 필드를 아예 건드리지 않는 경우 (프로필, 동의 등)
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['subscription'])
          ||
          // subscription 하위에서 pendingPlan('monthly'|'yearly')만 변경 허용
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['subscription'])
            && request.resource.data.subscription.diff(resource.data.subscription)
                .affectedKeys().hasOnly(['pendingPlan'])
            && request.resource.data.subscription.pendingPlan is string
            && request.resource.data.subscription.pendingPlan in ['monthly', 'yearly']
          )
        );
    }

    match /projects/{projectId} {
      allow read: if (request.auth != null && request.auth.uid == resource.data.ownerId)
                  || resource.data.shareEnabled == true;
      allow write: if request.auth != null && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
    }

    function isOwner(projectId) {
      return request.auth != null &&
        get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
    }

    function isShared(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)).data.shareEnabled == true;
    }

    match /characters/{id} {
      allow read: if isOwner(resource.data.projectId) || isShared(resource.data.projectId);
      allow create: if isOwner(request.resource.data.projectId);
      allow update: if isOwner(resource.data.projectId)
        && request.resource.data.projectId == resource.data.projectId;
      allow delete: if isOwner(resource.data.projectId);
    }
    match /relations/{id} {
      allow read: if isOwner(resource.data.projectId) || isShared(resource.data.projectId);
      allow create: if isOwner(request.resource.data.projectId);
      allow update: if isOwner(resource.data.projectId)
        && request.resource.data.projectId == resource.data.projectId;
      allow delete: if isOwner(resource.data.projectId);
    }
    match /foreshadows/{id} {
      allow read: if isOwner(resource.data.projectId) || isShared(resource.data.projectId);
      allow create: if isOwner(request.resource.data.projectId);
      allow update: if isOwner(resource.data.projectId)
        && request.resource.data.projectId == resource.data.projectId;
      allow delete: if isOwner(resource.data.projectId);
    }
    match /worldDocs/{id} {
      allow read: if isOwner(resource.data.projectId) || isShared(resource.data.projectId);
      allow create: if isOwner(request.resource.data.projectId);
      allow update: if isOwner(resource.data.projectId)
        && request.resource.data.projectId == resource.data.projectId;
      allow delete: if isOwner(resource.data.projectId);
    }
    match /timelineEvents/{id} {
      allow read: if isOwner(resource.data.projectId) || isShared(resource.data.projectId);
      allow create: if isOwner(request.resource.data.projectId);
      allow update: if isOwner(resource.data.projectId)
        && request.resource.data.projectId == resource.data.projectId;
      allow delete: if isOwner(resource.data.projectId);
    }
    match /fanworks/{id} {
      allow read: if isOwner(resource.data.projectId) || isShared(resource.data.projectId);
      allow create: if isOwner(request.resource.data.projectId);
      allow update: if isOwner(resource.data.projectId)
        && request.resource.data.projectId == resource.data.projectId;
      allow delete: if isOwner(resource.data.projectId);
    }

    // 쿠폰: 클라이언트 접근 완전 차단 (Cloud Functions 전용)
    match /coupons/{code} {
      allow read, write: if false;
    }

    // 결제 이력: 본인 것만 읽기 가능, 쓰기는 Cloud Functions 전용
    // (전자상거래법 5년 보관 의무용 — 영수증·환불·분쟁 추적)
    match /payments/{paymentId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      allow write: if false;
    }

    // 시스템 내부 메타데이터 (쿠폰 brute force 시도 기록 등)
    // Cloud Functions 전용 — 클라이언트 접근 완전 차단
    match /_system/{docId} {
      allow read, write: if false;
    }
  }
}
